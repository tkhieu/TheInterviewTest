# Copy to .env for local docker-compose; keep .env out of git (see .gitignore).

# --- Postgres (docker-compose service "db") -----------------------------------
POSTGRES_USER=campaign
POSTGRES_PASSWORD=campaign
POSTGRES_DB=campaign_manager
POSTGRES_PORT=5432

# DATABASE_URL is consumed by @campaign-manager/api (Sequelize).
# Inside docker-compose the host is "db"; for local dev outside compose use "localhost".
DATABASE_URL=postgres://campaign:campaign@db:5432/campaign_manager

# --- Backend (@campaign-manager/api) ------------------------------------------
API_PORT=4000
NODE_ENV=development

# Replace with a 32+ char random value before deploying anywhere non-local.
JWT_SECRET=replace-me-with-a-32-char-random-secret
JWT_EXPIRES_IN=7d

# bcrypt cost factor (10–12 is the sane range for this scope).
BCRYPT_ROUNDS=10

# --- Frontend (@campaign-manager/web, Vite) -----------------------------------
# All Vite env vars must be VITE_-prefixed to be exposed to the bundle.
VITE_API_BASE_URL=http://localhost:4000

# Mock-Service-Worker switches (see work-plan.md §7).
# Defaults to 0 so a fresh checkout talks to the real backend.
VITE_USE_MSW=0
VITE_USE_MSW_LIST=0
VITE_USE_MSW_SEND=0
